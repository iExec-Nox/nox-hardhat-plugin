{
  "name": "@iexec-nox/nox-hardhat-plugin",
  "version": "0.1.0-beta.0",
  "description": "Hardhat 3 plugin that spins up the Nox offchain stack and deploys NoxCompute for local end-to-end tests.",
  "license": "MIT",
  "type": "module",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": "./dist/src/index.js"
  },
  "keywords": [
    "ethereum",
    "smart-contracts",
    "hardhat",
    "hardhat3",
    "hardhat-plugin",
    "nox",
    "confidential"
  ],
  "scripts": {
    "lint": "pnpm prettier --check && pnpm eslint",
    "lint:fix": "pnpm prettier --write && pnpm eslint --fix",
    "eslint": "eslint \"src/**/*.ts\"",
    "prettier": "prettier \"**/*.{ts,js,md,json}\"",
    "test": "node --import tsx/esm --test \"test/**/*.ts\"",
    "build": "tsc --build .",
    "clean": "rimraf dist",
    "watch": "tsc --build . --watch"
  },
  "files": [
    "dist/src/",
    "src/",
    "offchain-services/",
    "CHANGELOG.md",
    "LICENSE",
    "README.md"
  ],
  "dependencies": {
    "@iexec-nox/handle": "^0.1.0-beta.11",
    "@iexec-nox/nox-protocol-contracts": "^0.2.4",
    "@openzeppelin/contracts": "^5.6.0",
    "docker-compose": "^1.2.0",
    "viem": "^2.46.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@tsconfig/node22": "^22.0.2",
    "@types/node": "^22.11.0",
    "eslint": "^9.35.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "hardhat": "^3.4.0",
    "prettier": "3.6.2",
    "rimraf": "^5.0.5",
    "tsx": "^4.19.3",
    "typescript": "~5.8.0",
    "typescript-eslint": "^8.43.0"
  },
  "peerDependencies": {
    "@nomicfoundation/hardhat-toolbox-viem": "^5.0.3",
    "hardhat": "^3.4.0"
  },
  "homepage": "https://github.com/iExec-Nox/nox-hardhat-plugin#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iExec-Nox/nox-hardhat-plugin.git"
  },
  "bugs": {
    "url": "https://github.com/iExec-Nox/nox-hardhat-plugin/issues"
  }
}
